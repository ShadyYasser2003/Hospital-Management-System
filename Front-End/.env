# Leave empty to use Vite dev-proxy (/api → http://localhost:8080)
# Set to full URL only when deploying to production
VITE_API_BASE_URL=

# Chatbot base URL — leave empty to use the Vite dev-proxy (/chatbot-api → AWS server).
# Set to a full URL only when deploying behind a CORS-enabled reverse proxy.
VITE_CHATBOT_BASE_URL=
