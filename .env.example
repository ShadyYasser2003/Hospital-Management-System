# =============================================================================
#  .env.example — Complete list of required environment variables
#  Copy to .env.production and fill with real values. NEVER commit real secrets.
# =============================================================================

# ── Database ────────────────────────────────────────────────────────────────
DATABASE_URL=jdbc:mysql://localhost:3306/hms_backend
DATABASE_USERNAME=YOUR_DB_USERNAME
DATABASE_PASSWORD=YOUR_DB_PASSWORD

# ── JWT ─────────────────────────────────────────────────────────────────────
JWT_SECRET=YOUR_JWT_SECRET_MINIMUM_64_CHARACTERS
JWT_ACCESS_TOKEN_EXPIRATION=900000
JWT_REFRESH_TOKEN_EXPIRATION=604800000

# ── Mail (SMTP) ─────────────────────────────────────────────────────────────
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=YOUR_EMAIL@gmail.com
MAIL_PASSWORD=YOUR_APP_PASSWORD

# ── PayPal ──────────────────────────────────────────────────────────────────
PAYPAL_CLIENT_ID=YOUR_PAYPAL_CLIENT_ID
PAYPAL_CLIENT_SECRET=YOUR_PAYPAL_CLIENT_SECRET
PAYPAL_MODE=sandbox

# ── Kashier (Payment Gateway) ───────────────────────────────────────────────
KASHIER_MERCHANT_ID=YOUR_MERCHANT_ID
KASHIER_API_KEY=YOUR_KASHIER_API_KEY
KASHIER_SECRET_KEY=YOUR_KASHIER_SECRET_KEY
KASHIER_MODE=test
KASHIER_REDIRECT_URL=https://yourdomain.com/api/kashier/payment/success
KASHIER_WEBHOOK_URL=https://yourdomain.com/api/kashier/webhook

# ── Hospital ────────────────────────────────────────────────────────────────
HOSPITAL_NAME=MediCore Hospital
HOSPITAL_EMAIL=YOUR_HOSPITAL_EMAIL
BLOOD_BANK_EMAIL=bloodbank@hospital.com

# ── Application ─────────────────────────────────────────────────────────────
SPRING_PROFILES_ACTIVE=production
SERVER_PORT=8080
CORS_ALLOWED_ORIGINS=https://yourdomain.com
UPLOAD_DIRECTORY=uploads/reports/

# ── Logging ─────────────────────────────────────────────────────────────────
LOGGING_LEVEL_ROOT=INFO
LOGGING_LEVEL_APP=INFO
JPA_DDL_AUTO=update
JPA_SHOW_SQL=false
JPA_FORMAT_SQL=false

# ── Frontend ────────────────────────────────────────────────────────────────
VITE_API_BASE_URL=https://yourdomain.com
